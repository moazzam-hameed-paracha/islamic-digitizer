# URL of the locally-running Qari OCR FastAPI server.
# Default is http://localhost:7860 — only set this if you changed the port
# or are running the server on a different machine/container.
OCR_SERVER_URL=http://localhost:7860

# Set to "false" to disable PDF uploads entirely (image-only mode).
# Useful if pdf.js or canvas support is unavailable in your environment.
NEXT_PUBLIC_ENABLE_PDF=true
