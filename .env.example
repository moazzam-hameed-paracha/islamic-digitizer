# .env.local
# ─────────────────────────────────────────────────────────────────────────────
# URL of the locally-running Qari OCR Gradio server.
# Default is http://localhost:7860 — only set this if you changed the port
# or are running Gradio on a different machine/container.
# ─────────────────────────────────────────────────────────────────────────────
GRADIO_URL=http://localhost:7860
